{
  "$schema": "https://raw.githubusercontent.com/code-yeongyu/oh-my-openagent/master/assets/oh-my-openagent.schema.json",
  "options": {
    "ultrawork_mode": "disabled"
  },
  "auto_update": false,
  "model_fallback": true,
  "disabled_hooks": [
    "keyword-detector",
    "prometheus-planner",
    "deep-entity",
    "ulw-loop"
  ],
  "disabled_mcps": ["context7", "grep_app"],
  "experimental": {
    "aggressive_truncation": true,
    "task_system": true,
    "auto_resume": true
  },
  "background_task": {
    "defaultConcurrency": 5,
    "staleTimeoutMs": 180000
  },
  "sisyphus_agent": {
    "default_builder_enabled": false,
    "planner_enabled": true,
    "replace_plan": true
  },
  "git_master": {
    "commit_footer": false,
    "include_co_authored_by": false
  },
  "start_work": {
    "auto_commit": false
  },
  "agents": {
    "sisyphus": {
      "model": "opencode/big-pickle",
      "permission": {
        "edit": "allow",
        "bash": "allow",
        "external_directory": "allow"
      }
    },
    "atlas": { "model": "opencode/big-pickle" },
    "oracle": { "model": "opencode/big-pickle" },
    "librarian": { "model": "opencode/big-pickle" },
    "explore": { "model": "opencode/big-pickle" },
    "prometheus": { "model": "opencode/big-pickle" },
    "multimodal-looker": { "model": "opencode/big-pickle" },
    "hephaestus": { "model": "opencode/kimi-k2.5" },
    "metis": { "model": "opencode/big-pickle" },
    "momus": { "model": "opencode/kimi-k2.5" }
  },
  "categories": {
    "quick": { "model": "opencode/big-pickle" },
    "visual-engineering": { "model": "opencode/big-pickle" },
    "ultrabrain": { "model": "opencode/kimi-k2.5" },
    "deep": { "model": "opencode/kimi-k2.5" },
    "unspecified-low": { "model": "opencode/big-pickle" },
    "unspecified-high": { "model": "opencode/big-pickle" },
    "writing": { "model": "opencode/big-pickle" }
  }
}