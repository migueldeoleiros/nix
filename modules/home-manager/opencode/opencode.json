{
  "$schema": "https://opencode.ai/config.json",
  "default_agent": "assistant",
  "plugin": [
    "opencode-vibeguard",
    "@tarquinen/opencode-dcp",
    "@mohak34/opencode-notifier"
  ],
  "mcp": {
    "chrome-devtools": {
      "type": "local",
      "enabled": true,
      "command": [
        "opencode-chromium-devtools-mcp"
      ]
    },
    "trivy": {
      "type": "local",
      "enabled": true,
      "command": [
        "opencode-trivy-mcp"
      ],
      "timeout": 120000
    },
    "sonarqube": {
      "type": "local",
      "enabled": true,
      "command": [
        "docker",
        "run",
        "--init",
        "--rm",
        "--network=host",
        "-i",
        "-e",
        "SONARQUBE_TOKEN",
        "-e",
        "SONARQUBE_URL",
        "mcp/sonarqube"
      ],
      "environment": {
        "SONARQUBE_TOKEN": "{file:/home/miguel/.config/opencode/keys/sonarqube.key}",
        "SONARQUBE_URL": "{file:/home/miguel/.config/opencode/keys/sonarqube.url}"
      },
      "timeout": 60000
    },
    "gitea": {
      "type": "local",
      "enabled": true,
      "command": [
        "opencode-gitea-mcp"
      ],
      "timeout": 60000
    }
  },
  "small_model": "opencode/big-pickle",
  "agent": {
    "quick": {
      "model": "opencode/big-pickle",
      "reasoningEffort": "low",
      "prompt": "{file:./agent-prompts/quick.md}",
      "description": "Lightweight primary workflow for simple, low-risk tasks",
      "color": "#9ccc65",
      "permission": {
        "chrome-devtools_*": "deny",
        "trivy_*": "deny",
        "sonarqube_*": "deny",
        "bash": {
          "*": "ask",
          "git status*": "allow",
          "git log*": "allow",
          "git diff*": "allow",
          "git show*": "allow",
          "rg *": "allow",
          "ls *": "allow",
          "ls": "allow",
          "pwd": "allow"
        },
        "task": {
          "*": "deny"
        },
        "edit": "ask",
        "gitea_*": "deny"
      },
      "mode": "primary"
    },
    "assistant": {
      "model": "openai/gpt-5.6-terra",
      "reasoningEffort": "low",
      "prompt": "{file:./agent-prompts/assistant.md}",
      "description": "User-facing collaborative workflow for questions, analysis, and guided task support",
      "color": "#4fc3f7",
      "permission": {
        "chrome-devtools_*": "deny",
        "trivy_*": "allow",
        "sonarqube_*": "deny",
        "edit": "allow",
        "bash": {
          "*": "allow",
          "git commit*": "ask",
          "git push*": "ask",
          "git rebase*": "ask",
          "git reset*": "ask",
          "git clean*": "ask",
          "git restore*": "ask",
          "git checkout*": "ask",
          "sudo *": "ask",
          "su *": "ask",
          "doas *": "ask",
          "rm*": "ask",
          "rmdir*": "ask",
          "unlink*": "ask",
          "shred*": "ask"
        },
        "task": {
          "*": "deny",
          "investigate": "allow",
          "reviewer": "allow",
          "verifier": "allow",
          "general": "allow"
        },
        "gitea_*": "deny"
      },
      "mode": "primary"
    },
    "build": {
      "model": "openai/gpt-5.6-sol",
      "reasoningEffort": "low",
      "prompt": "{file:./agent-prompts/build.md}",
      "description": "Primary implementation agent; delegate discovery to investigate, risk analysis to reviewer, and proof checks to verifier",
      "color": "#ffb74d",
      "permission": {
        "chrome-devtools_*": "deny",
        "trivy_*": "allow",
        "sonarqube_*": "deny",
        "task": {
          "*": "deny",
          "investigate": "allow",
          "reviewer": "allow",
          "verifier": "allow",
          "worker": "allow",
          "spec-writer": "allow",
          "general": "allow"
        },
        "bash": {
          "*": "allow",
          "git status*": "allow",
          "git log*": "allow",
          "git diff*": "allow",
          "git show*": "allow",
          "rg *": "allow",
          "ls *": "allow",
          "ls": "allow",
          "pwd": "allow",
          "git commit*": "ask",
          "git push*": "ask",
          "git rebase*": "ask",
          "git reset*": "ask",
          "git clean*": "ask",
          "git restore*": "ask",
          "git checkout*": "ask",
          "sudo *": "ask",
          "su *": "ask",
          "doas *": "ask",
          "rm*": "ask",
          "rmdir*": "ask",
          "unlink*": "ask",
          "shred*": "ask"
        },
        "edit": "allow",
        "gitea_*": "deny"
      },
      "mode": "primary"
    },
    "plan": {
      "model": "openai/gpt-5.6-sol",
      "reasoningEffort": "medium",
      "prompt": "{file:./agent-prompts/plan.md}",
      "description": "Read-only planning workflow for scope clarification, sequencing, and risk-aware execution plans",
      "color": "#ba68c8",
      "permission": {
        "chrome-devtools_*": "deny",
        "trivy_*": "deny",
        "sonarqube_*": "deny",
        "read": "allow",
        "glob": "allow",
        "grep": "allow",
        "list": "allow",
        "task": {
          "*": "deny",
          "investigate": "allow",
          "reviewer": "allow",
          "spec-writer": "allow"
        },
        "skill": "allow",
        "edit": "deny",
        "bash": {
          "*": "deny",
          "pwd": "allow",
          "ls *": "allow",
          "ls": "allow",
          "git status*": "allow",
          "git log*": "allow",
          "git diff*": "allow",
          "rg *": "allow"
        },
        "webfetch": "allow",
        "gitea_*": "deny"
      },
      "mode": "primary"
    },
    "investigate": {
      "mode": "subagent",
      "model": "openai/gpt-5.6-terra",
      "reasoningEffort": "none",
      "prompt": "{file:./agent-prompts/investigate.md}",
      "description": "Use for fast read-only research, repo exploration, and web lookups before implementation decisions",
      "color": "#64b5f6",
      "permission": {
        "chrome-devtools_*": "allow",
        "trivy_*": "allow",
        "sonarqube_*": "deny",
        "read": "allow",
        "glob": "allow",
        "grep": "allow",
        "webfetch": "allow",
        "edit": "deny",
        "bash": {
          "*": "deny"
        },
        "task": {
          "*": "deny"
        },
        "gitea_*": "deny"
      }
    },
    "reviewer": {
      "mode": "subagent",
      "model": "openai/gpt-5.6-sol",
      "reasoningEffort": "medium",
      "prompt": "{file:./agent-prompts/reviewer.md}",
      "description": "Use for deep code/PR review: logic bugs, regressions, duplication, scalability limits, and reliability issues",
      "color": "#e57373",
      "permission": {
        "chrome-devtools_*": "allow",
        "trivy_*": "allow",
        "sonarqube_*": "allow",
        "read": "allow",
        "glob": "allow",
        "grep": "allow",
        "webfetch": "allow",
        "edit": "deny",
        "bash": {
          "*": "deny"
        },
        "task": {
          "*": "deny"
        },
        "gitea_*": "deny"
      }
    },
    "verifier": {
      "mode": "subagent",
      "model": "openai/gpt-5.6-terra",
      "reasoningEffort": "low",
      "prompt": "{file:./agent-prompts/verifier.md}",
      "description": "Use when claims need proof: run tests/checks, inspect outputs, and report evidence-based verification results",
      "color": "#4db6ac",
      "permission": {
        "chrome-devtools_*": "allow",
        "trivy_*": "allow",
        "sonarqube_*": "deny",
        "read": "allow",
        "glob": "allow",
        "grep": "allow",
        "bash": {
          "*": "allow",
          "git commit*": "ask",
          "git push*": "ask",
          "git rebase*": "ask",
          "git reset*": "ask",
          "git clean*": "ask",
          "git restore*": "ask",
          "git checkout*": "ask",
          "sudo *": "ask",
          "su *": "ask",
          "doas *": "ask",
          "rm*": "ask",
          "rmdir*": "ask",
          "unlink*": "ask",
          "shred*": "ask"
        },
        "edit": "deny",
        "webfetch": "deny",
        "task": {
          "*": "deny"
        },
        "gitea_*": "deny"
      }
    },
    "spec-writer": {
      "mode": "subagent",
      "model": "openai/gpt-5.6-terra",
      "reasoningEffort": "low",
      "prompt": "{file:./agent-prompts/spec-writer.md}",
      "description": "Writes and updates local temporary planning specs under .opencode/specs only",
      "hidden": true,
      "permission": {
        "chrome-devtools_*": "deny",
        "trivy_*": "deny",
        "sonarqube_*": "deny",
        "read": "allow",
        "glob": "allow",
        "grep": "allow",
        "edit": {
          "*": "deny",
          ".opencode/specs/**": "allow"
        },
        "bash": {
          "*": "deny"
        },
        "external_directory": "deny",
        "task": {
          "*": "deny"
        },
        "gitea_*": "deny"
      }
    },
    "general": {
      "mode": "subagent",
      "model": "openai/gpt-5.6-terra",
      "reasoningEffort": "low",
      "prompt": "{file:./agent-prompts/general.md}",
      "description": "Fallback delegated agent for mixed tasks that do not clearly fit investigate, reviewer, or verifier",
      "color": "#90a4ae",
      "permission": {
        "chrome-devtools_*": "deny",
        "trivy_*": "deny",
        "sonarqube_*": "deny",
        "bash": {
          "*": "ask",
          "git status*": "allow",
          "git log*": "allow",
          "git diff*": "allow",
          "git show*": "allow",
          "rg *": "allow",
          "ls *": "allow",
          "ls": "allow",
          "pwd": "allow"
        },
        "task": {
          "*": "deny",
          "investigate": "allow",
          "reviewer": "allow",
          "verifier": "allow"
        },
        "edit": "deny",
        "gitea_*": "deny"
      }
    },
    "worker": {
      "mode": "subagent",
      "model": "openai/gpt-5.6-terra",
      "reasoningEffort": "none",
      "prompt": "{file:./agent-prompts/worker.md}",
      "description": "Dedicated execution subagent for complex multi-step edits and tool-heavy implementation work",
      "color": "#ffd54f",
      "permission": {
        "chrome-devtools_*": "allow",
        "trivy_*": "allow",
        "sonarqube_*": "deny",
        "bash": {
          "*": "allow",
          "git commit*": "ask",
          "git push*": "ask",
          "git rebase*": "ask",
          "git reset*": "ask",
          "git clean*": "ask",
          "git restore*": "ask",
          "rm*": "ask",
          "rmdir*": "ask",
          "unlink*": "ask",
          "shred*": "ask"
        },
        "task": {
          "*": "deny",
          "investigate": "allow",
          "reviewer": "allow",
          "verifier": "allow"
        },
        "edit": "allow",
        "gitea_*": "deny"
      }
    },
    "gitea-repo": {
      "model": "openai/gpt-5.6-terra",
      "reasoningEffort": "low",
      "prompt": "{file:./agent-prompts/gitea-repo.md}",
      "description": "User-facing Gitea repository management agent for issues, PRs, repo hygiene, and release/changelog workflows",
      "color": "#81c784",
      "permission": {
        "gitea_*": "deny",
        "gitea_get_*": "allow",
        "gitea_list_*": "allow",
        "gitea_search_*": "allow",
        "gitea_render_*": "allow",
        "gitea_create_*": "ask",
        "gitea_edit_*": "ask",
        "gitea_update_*": "ask",
        "gitea_request_*": "ask",
        "gitea_fork_*": "ask",
        "gitea_star_*": "ask",
        "gitea_unstar_*": "ask",
        "gitea_mark_*": "ask",
        "gitea_add_issue_*": "ask",
        "gitea_remove_issue_*": "ask",
        "gitea_admin_*": "deny",
        "gitea_delete_*": "deny",
        "gitea_transfer_*": "deny",
        "gitea_merge_*": "deny",
        "gitea_add_collaborator": "deny",
        "gitea_add_team_*": "deny",
        "gitea_remove_team_*": "deny",
        "gitea_create_org": "deny",
        "gitea_edit_org": "deny",
        "gitea_create_team": "deny",
        "gitea_get_runner_registration_token": "deny",
        "chrome-devtools_*": "deny",
        "trivy_*": "deny",
        "sonarqube_*": "deny",
        "read": "allow",
        "glob": "allow",
        "grep": "allow",
        "webfetch": "allow",
        "edit": "deny",
        "bash": {
          "*": "ask",
          "git *": "allow",
          "docker *": "allow",
          "docker compose *": "allow",
          "act*": "allow",
          "python*": "allow",
          "* test*": "allow",
          "* build*": "allow",
          "* lint*": "allow",
          "* typecheck*": "allow",
          "* check*": "allow",
          "* verify*": "allow",
          "* compile*": "allow",
          "rg *": "allow",
          "ls*": "allow",
          "pwd": "allow",
          "git commit*": "ask",
          "git push*": "ask",
          "git rebase*": "ask",
          "git reset*": "ask",
          "git clean*": "ask",
          "git restore*": "ask",
          "rm*": "ask",
          "rmdir*": "ask",
          "unlink*": "ask",
          "shred*": "ask"
        },
        "task": {
          "*": "deny",
          "investigate": "allow",
          "reviewer": "allow",
          "verifier": "allow",
          "general": "allow"
        }
      },
      "mode": "primary"
    }
  },
  "provider": {
    "openai": {
      "name": "MerlinLLM",
      "whitelist": [
        "gpt-5.6-sol",
        "gpt-5.6-terra",
        "gpt-5.5",
        "gpt-5.4-mini"
      ],
      "options": {
        "baseURL": "https://ai.int.merlinsoftware.es/v1",
        "apiKey": "{file:/home/miguel/.config/opencode/keys/merlin.key}"
      }
    }
  }
}
