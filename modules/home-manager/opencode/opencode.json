{
  "$schema": "https://opencode.ai/config.json",
  "default_agent": "assistant",
  "plugin": [
    "opencode-vibeguard",
    "@tarquinen/opencode-dcp",
    "@mohak34/opencode-notifier"
  ],
  "mcp": {
    "chrome-devtools": {
      "type": "local",
      "enabled": true,
      "command": ["opencode-chromium-devtools-mcp"]
    },
    "sonarqube": {
      "type": "local",
      "enabled": true,
      "command": [
        "docker",
        "run",
        "--init",
        "--rm",
        "--network=host",
        "-i",
        "-e",
        "SONARQUBE_TOKEN={file:/home/miguel/.config/opencode/keys/sonarqube.key}",
        "-e",
        "SONARQUBE_URL={file:/home/miguel/.config/opencode/keys/sonarqube.url}",
        "mcp/sonarqube"
      ],
      "timeout": 60000
    }
  },
  "small_model": "opencode/big-pickle",
  "agent": {
    "quick": {
      "model": "opencode/big-pickle",
      "prompt": "{file:./agents/quick.md}",
      "description": "Lightweight primary workflow for simple, low-risk tasks",
      "permission": {
        "chrome-devtools_*": "deny",
        "sonarqube_*": "deny",
        "bash": {
          "git commit*": "ask",
          "git push*": "ask",
          "git rebase*": "ask",
          "git reset*": "ask",
          "git clean*": "ask",
          "git restore*": "ask",
          "rm*": "ask",
          "rmdir*": "ask",
          "unlink*": "ask",
          "shred*": "ask",
          "*": "allow"
        }
      }
    },
    "assistant": {
      "model": "litellm/chatgpt/gpt-5.5",
      "prompt": "{file:./agents/assistant.md}",
      "description": "User-facing collaborative workflow for questions, analysis, and guided task support",
      "permission": {
        "chrome-devtools_*": "deny",
        "sonarqube_*": "deny",
        "edit": "ask",
        "bash": {
          "git commit*": "ask",
          "git push*": "ask",
          "git rebase*": "ask",
          "git reset*": "ask",
          "git clean*": "ask",
          "git restore*": "ask",
          "rm*": "ask",
          "rmdir*": "ask",
          "unlink*": "ask",
          "shred*": "ask",
          "*": "allow"
        }
      }
    },
    "build": {
      "model": "litellm/chatgpt/gpt-5.5",
      "prompt": "{file:./agents/build.md}",
      "description": "Primary implementation agent; delegate discovery to investigate, risk analysis to reviewer, and proof checks to verifier",
      "permission": {
        "chrome-devtools_*": "deny",
        "sonarqube_*": "deny",
        "task": "allow",
        "bash": {
          "git commit*": "ask",
          "git push*": "ask",
          "git rebase*": "ask",
          "git reset*": "ask",
          "git clean*": "ask",
          "git restore*": "ask",
          "rm*": "ask",
          "rmdir*": "ask",
          "unlink*": "ask",
          "shred*": "ask",
          "*": "allow"
        }
      }
    },
    "plan": {
      "model": "litellm/chatgpt/gpt-5.5",
      "prompt": "{file:./agents/plan.md}",
      "description": "Read-only planning workflow for scope clarification, sequencing, and risk-aware execution plans",
      "permission": {
        "chrome-devtools_*": "deny",
        "sonarqube_*": "deny",
        "read": "allow",
        "glob": "allow",
        "grep": "allow",
        "list": "allow",
        "task": {
          "*": "deny",
          "investigate": "allow",
          "reviewer": "allow",
          "spec-writer": "allow"
        },
        "skill": "allow",
        "edit": "deny",
        "bash": {
          "*": "deny",
          "pwd": "allow",
          "ls *": "allow",
          "git status*": "allow",
          "git log*": "allow",
          "git diff*": "allow",
          "rg *": "allow"
        },
        "webfetch": "allow"
      }
    },
    "investigate": {
      "mode": "subagent",
      "model": "litellm/chatgpt/gpt-5.5",
      "prompt": "{file:./agents/investigate.md}",
      "description": "Use for fast read-only research, repo exploration, and web lookups before implementation decisions",
      "permission": {
        "chrome-devtools_*": "allow",
        "sonarqube_*": "deny",
        "read": "allow",
        "glob": "allow",
        "grep": "allow",
        "webfetch": "allow",
        "edit": "deny",
        "write": "deny",
        "bash": {
          "*": "deny"
        }
      }
    },
    "reviewer": {
      "mode": "subagent",
      "model": "litellm/chatgpt/gpt-5.5",
      "prompt": "{file:./agents/reviewer.md}",
      "description": "Use for deep code/PR review: logic bugs, regressions, duplication, scalability limits, and reliability issues",
      "permission": {
        "chrome-devtools_*": "allow",
        "sonarqube_*": "allow",
        "read": "allow",
        "glob": "allow",
        "grep": "allow",
        "webfetch": "allow",
        "edit": "deny",
        "write": "deny",
        "bash": {
          "*": "deny"
        }
      }
    },
    "verifier": {
      "mode": "subagent",
      "model": "litellm/chatgpt/gpt-5.5",
      "prompt": "{file:./agents/verifier.md}",
      "description": "Use when claims need proof: run tests/checks, inspect outputs, and report evidence-based verification results",
      "permission": {
        "chrome-devtools_*": "allow",
        "sonarqube_*": "deny",
        "read": "allow",
        "glob": "allow",
        "grep": "allow",
        "bash": {
          "git commit*": "ask",
          "git push*": "ask",
          "git rebase*": "ask",
          "git reset*": "ask",
          "git clean*": "ask",
          "git restore*": "ask",
          "rm*": "ask",
          "rmdir*": "ask",
          "unlink*": "ask",
          "shred*": "ask",
          "*": "allow"
        },
        "edit": "deny",
        "write": "deny",
        "webfetch": "deny"
      }
    },
    "spec-writer": {
      "mode": "subagent",
      "model": "litellm/chatgpt/gpt-5.5",
      "prompt": "{file:./agents/spec-writer.md}",
      "description": "Writes and updates local temporary planning specs under .opencode/specs only",
      "hidden": true,
      "permission": {
        "chrome-devtools_*": "deny",
        "sonarqube_*": "deny",
        "read": "allow",
        "glob": "allow",
        "grep": "allow",
        "edit": {
          "*": "deny",
          ".opencode/specs/*.md": "allow"
        },
        "write": {
          "*": "deny",
          ".opencode/specs/*.md": "allow"
        },
        "bash": {
          "*": "deny"
        },
        "external_directory": "deny"
      }
    },
    "general": {
      "mode": "subagent",
      "model": "litellm/chatgpt/gpt-5.5",
      "prompt": "{file:./agents/general.md}",
      "description": "Fallback delegated agent for mixed tasks that do not clearly fit investigate, reviewer, or verifier",
      "permission": {
        "chrome-devtools_*": "deny",
        "sonarqube_*": "deny",
        "bash": {
          "git commit*": "ask",
          "git push*": "ask",
          "git rebase*": "ask",
          "git reset*": "ask",
          "git clean*": "ask",
          "git restore*": "ask",
          "rm*": "ask",
          "rmdir*": "ask",
          "unlink*": "ask",
          "shred*": "ask",
          "*": "allow"
        }
      }
    },
    "worker": {
      "mode": "subagent",
      "model": "litellm/chatgpt/gpt-5.5",
      "prompt": "{file:./agents/worker.md}",
      "description": "Dedicated execution subagent for complex multi-step edits and tool-heavy implementation work",
      "permission": {
        "chrome-devtools_*": "allow",
        "sonarqube_*": "deny",
        "bash": {
          "git commit*": "ask",
          "git push*": "ask",
          "git rebase*": "ask",
          "git reset*": "ask",
          "git clean*": "ask",
          "git restore*": "ask",
          "rm*": "ask",
          "rmdir*": "ask",
          "unlink*": "ask",
          "shred*": "ask",
          "*": "allow"
        }
      }
    }
  },
  "provider": {
    "litellm": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "LiteLLM",
      "options": {
        "baseURL": "https://ai.int.merlinsoftware.es/v1",
        "apiKey": "{file:/home/miguel/.config/opencode/keys/merlin.key}"
      },
      "models": {
        "chatgpt/gpt-5.5": {
          "name": "GPT-5.5"
        },
        "chatgpt/gpt-5.4": {
          "name": "GPT-5.4"
        },
        "chatgpt/gpt-5.3-codex": {
          "name": "GPT-5.3 Codex"
        }
      }
    }
  }
}
