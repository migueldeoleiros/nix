          "git push*": "ask",
          "git rebase*": "ask",
          "git reset*": "ask",
          "git clean*": "ask",
          "git restore*": "ask",
          "rm*": "ask",
          "rmdir*": "ask",
          "unlink*": "ask",
          "shred*": "ask"
        },
        "task": {
          "*": "deny",
          "investigate": "allow",
          "reviewer": "allow",
          "verifier": "allow",
          "general": "allow"
