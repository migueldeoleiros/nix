{
  "$schema": "https://opencode.ai/config.json",
  "default_agent": "assistant",
  "plugin": [
    "opencode-vibeguard",
    "@tarquinen/opencode-dcp",
    "@mohak34/opencode-notifier"
  ],
  "mcp": {
    "chrome-devtools": {
      "type": "local",
      "enabled": true,
      "command": [
        "opencode-chromium-devtools-mcp"
      ]
    },
    "trivy": {
      "type": "local",
      "enabled": true,
      "command": [
        "opencode-trivy-mcp"
      ],
      "timeout": 120000
    },
    "sonarqube": {
      "type": "local",
      "enabled": true,
      "command": [
        "docker",
        "run",
        "--init",
        "--rm",
        "--network=host",
        "-i",
        "-e",
        "SONARQUBE_TOKEN",
        "-e",
        "SONARQUBE_URL",
        "mcp/sonarqube"
      ],
      "environment": {
        "SONARQUBE_TOKEN": "{file:/home/miguel/.config/opencode/keys/sonarqube.key}",
        "SONARQUBE_URL": "{file:/home/miguel/.config/opencode/keys/sonarqube.url}"
      },
      "timeout": 60000
    },
    "gitea": {
      "type": "local",
      "enabled": true,
      "command": [
        "opencode-gitea-mcp"
      ],
      "timeout": 60000
    }
  },
  "small_model": "opencode/big-pickle",
  "agent": {
    "quick": {
      "model": "opencode/big-pickle",
      "prompt": "{file:./agent-prompts/quick.md}",
      "description": "Lightweight primary workflow for simple, low-risk tasks",
      "color": "#9ccc65",
      "permission": {
        "chrome-devtools_*": "deny",
        "trivy_*": "deny",
        "sonarqube_*": "deny",
        "bash": {
          "*": "ask",
          "git status*": "allow",
          "git log*": "allow",
          "git diff*": "allow",
          "git show*": "allow",
          "rg *": "allow",
          "ls *": "allow",
          "ls": "allow",
          "pwd": "allow",
          "git commit*": "ask",
          "git push*": "ask",
          "git rebase*": "ask",
          "git reset*": "ask",
          "git clean*": "ask",
          "git restore*": "ask",
          "rm*": "ask",
          "rmdir*": "ask",
          "unlink*": "ask",
          "shred*": "ask"
        },
        "task": {
          "*": "deny"
        },
        "edit": "allow",
        "gitea_*": "deny"
      },
      "mode": "primary"
    },
    "assistant": {
      "model": "openai/gpt-5.5",
      "prompt": "{file:./agent-prompts/assistant.md}",
      "description": "User-facing collaborative workflow for questions, analysis, and guided task support",
      "color": "#4fc3f7",
      "permission": {
        "chrome-devtools_*": "deny",
        "trivy_*": "allow",
        "sonarqube_*": "deny",
        "edit": "ask",
