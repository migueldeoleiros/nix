#!/bin/sh

# Keep NetworkManager calls bounded; eww polls this script and blocks the bar
# while it waits for output.
devices=$(timeout 1s nmcli -t -f DEVICE,TYPE,STATE device status 2>/dev/null)

# Detect active ethernet via NetworkManager instead of interface name guesses.
eth_iface=$(printf '%s\n' "$devices" | awk -F: '$2 == "ethernet" && $3 == "connected" {print $1; exit}')
if [ -n "$eth_iface" ]; then
  eth=$(ip -4 -o addr show dev "$eth_iface" 2>/dev/null | awk '{sub(/\/.*$/, "", $4); print $4; exit}')
fi

# Detect connected wifi and signal strength. A connected interface without a
# visible signal still counts as wifi so the bar does not show the crossed icon.
wifi_iface=$(printf '%s\n' "$devices" | awk -F: '$2 == "wifi" && $3 == "connected" {print $1; exit}')
if [ -n "$wifi_iface" ]; then
  wifi=$(awk -v iface="$wifi_iface" '$1 == iface ":" {quality = ($3 + 0) / 70; if (quality > 1) quality = 1; print quality; exit}' /proc/net/wireless 2>/dev/null)
  wifi=${wifi:-0}
fi

# Return json
if [ -n "$eth" ]; then
  printf '{"network":"eth","ip":"%s"}\n' "$eth"
elif [ -n "$wifi_iface" ]; then
  printf '{"network":"wifi","conn":%s}\n' "$wifi"
else
  echo 'null'
fi
